---
---
<canvas id="percolation-canvas" class="fixed top-0 left-0 w-full h-full -z-10"></canvas>

<script>
    /** CONFIGURATION **/
    const CONFIG = {
        latticeScale: 15,         // Larger grid for background
        lineWidth: 2,            // Subtle thickness
        growthSpeed: 3,          // Steps per frame
        expansionRate: 3,        // Branches per step per color
        colorRed: 'rgba(230, 57, 70, 0.3)',   // Transparent Red
        colorBlue: 'rgba(145, 180, 204, 0.3)',  // Transparent Blue
        bgLineColor: 'rgba(40, 40, 40, 0.15)',  // Very faint grid
    };

    let canvas: HTMLCanvasElement;
    let ctx: CanvasRenderingContext2D;
    let width: number, height: number, cols: number, rows: number;
    
    interface Edge {
        n1: string; n2: string;
        x1: number; y1: number;
        x2: number; y2: number;
        weight: number; state: number;
    }

    let edges: Edge[] = [];
    let redNodes = new Set<string>();
    let blueNodes = new Set<string>();
    let redBoundary: Edge[] = [];
    let blueBoundary: Edge[] = [];
    let isFull = false;

    function init() {
        canvas = document.getElementById('percolation-canvas') as HTMLCanvasElement;
        if (!canvas) return;
        ctx = canvas.getContext('2d')!;
        
        setup();
        animate();
    }

    function setup() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
        
        cols = Math.ceil(width / CONFIG.latticeScale) + 1;
        rows = Math.ceil(height / CONFIG.latticeScale) + 1;
        
        edges = [];
        redNodes.clear();
        blueNodes.clear();
        isFull = false;

        for (let i = 0; i < cols; i++) {
            for (let j = 0; j < rows; j++) {
                const x = i * CONFIG.latticeScale;
                const y = j * CONFIG.latticeScale;
                
                // Horizontal edge (with wrapping)
                if (i < cols - 1 || true) { // Always create horizontally
                    const nextI = (i + 1) % cols;
                    edges.push({ 
                        n1: `${i},${j}`, n2: `${nextI},${j}`,
                        x1: x, y1: y, x2: nextI * CONFIG.latticeScale, y2: j * CONFIG.latticeScale,
                        weight: Math.random(), state: 0,
                        isWrap: nextI < i
                    });
                    if (i === cols - 1) edges[edges.length-1].x2 = width + CONFIG.latticeScale; // visual fix
                }
                
                // Vertical edge (with wrapping)
                if (j < rows - 1 || true) { // Always create vertically
                    const nextJ = (j + 1) % rows;
                    edges.push({ 
                        n1: `${i},${j}`, n2: `${i},${nextJ}`,
                        x1: x, y1: y, x2: i * CONFIG.latticeScale, y2: nextJ * CONFIG.latticeScale,
                        weight: Math.random(), state: 0,
                        isWrap: nextJ < j
                    });
                    if (j === rows - 1) edges[edges.length-1].y2 = height + CONFIG.latticeScale; // visual fix
                }
            }
        }

        // 3 initial points for each color
        for (let k = 0; k < 3; k++) {
            redNodes.add(`${Math.floor(Math.random() * cols)},${Math.floor(Math.random() * rows)}`);
            blueNodes.add(`${Math.floor(Math.random() * cols)},${Math.floor(Math.random() * rows)}`);
        }

        updateBoundaries();
    }

    function updateBoundaries() {
        redBoundary = [];
        blueBoundary = [];
        for (let e of edges) {
            if (e.state !== 0) continue;
            
            const r1 = redNodes.has(e.n1), r2 = redNodes.has(e.n2);
            const b1 = blueNodes.has(e.n1), b2 = blueNodes.has(e.n2);

            if ((r1 && !r2 && !blueNodes.has(e.n2)) || (r2 && !r1 && !blueNodes.has(e.n1))) {
                redBoundary.push(e);
            }
            if ((b1 && !b2 && !redNodes.has(e.n2)) || (b2 && !b1 && !redNodes.has(e.n1))) {
                blueBoundary.push(e);
            }
        }
    }

    function draw() {
        ctx.clearRect(0, 0, width, height);
        
        // Background grid
        ctx.strokeStyle = CONFIG.bgLineColor;
        ctx.lineWidth = 1;
        ctx.beginPath();
        for (let e of edges) {
            if (e.state === 0) {
                ctx.moveTo(e.x1, e.y1);
                ctx.lineTo(e.x2, e.y2);
            }
        }
        ctx.stroke();

        // Fluids
        ctx.lineWidth = CONFIG.lineWidth;
        ctx.lineCap = 'round';
        
        // Red
        ctx.strokeStyle = CONFIG.colorRed;
        ctx.beginPath();
        for (let e of edges) {
            if (e.state === 1) {
                ctx.moveTo(e.x1, e.y1);
                ctx.lineTo(e.x2, e.y2);
            }
        }
        ctx.stroke();

        // Blue
        ctx.strokeStyle = CONFIG.colorBlue;
        ctx.beginPath();
        for (let e of edges) {
            if (e.state === 2) {
                ctx.moveTo(e.x1, e.y1);
                ctx.lineTo(e.x2, e.y2);
            }
        }
        ctx.stroke();
    }

    function animate() {
        if (!isFull) {
            let modified = false;
            for (let s = 0; s < CONFIG.growthSpeed; s++) {
                // Expansion: Pick the best N edges for EACH color in this step
                redBoundary.sort((a,b) => a.weight - b.weight);
                blueBoundary.sort((a,b) => a.weight - b.weight);

                const color1Moves = redBoundary.slice(0, CONFIG.expansionRate);
                const color2Moves = blueBoundary.slice(0, CONFIG.expansionRate);

                if (color1Moves.length === 0 && color2Moves.length === 0) break;

                color1Moves.forEach(e => {
                    if (e.state === 0) {
                        e.state = 1; redNodes.add(e.n1); redNodes.add(e.n2);
                        modified = true;
                    }
                });
                color2Moves.forEach(e => {
                    if (e.state === 0) {
                        e.state = 2; blueNodes.add(e.n1); blueNodes.add(e.n2);
                        modified = true;
                    }
                });

                if (modified) updateBoundaries();
                else { isFull = true; break; }
            }
        }

        draw();
        requestAnimationFrame(animate);
    }

    window.addEventListener('resize', setup);
    init();
</script>
