---
---
<canvas id="percolation-canvas" class="fixed top-0 left-0 w-full h-full -z-10"></canvas>

<script>
    /** CONFIGURATION **/
    const CONFIG = {
        latticeScale: 8,         // Grid density
        lineWidth: 1.0,          // Subtle thickness
        growthSpeed: 15,          // Steps per frame
        expansionRate: 3,        // Branches per step per color
        threshold: 0.8,          // Physical limit for invasion
        colorRed: 'rgba(230, 57, 70, 0.3)',   // Transparent Red
        colorBlue: 'rgba(145, 180, 204, 0.3)',  // Transparent Blue
        bgLineColor: 'rgba(40, 40, 40, 0.15)',  // Very faint grid
    };

    /** MIN-HEAP FOR PERCOLATION PERFORMANCE **/
    class MinHeap {
        heap: { edge: Edge; weight: number }[] = [];
        push(node: { edge: Edge; weight: number }) {
            this.heap.push(node);
            this.bubbleUp();
        }
        pop() {
            if (this.size() === 0) return null;
            if (this.size() === 1) return this.heap.pop();
            const min = this.heap[0];
            this.heap[0] = this.heap.pop()!;
            this.bubbleDown();
            return min;
        }
        peek() {
            return this.size() > 0 ? this.heap[0] : null;
        }
        size() { return this.heap.length; }
        bubbleUp() {
            let idx = this.heap.length - 1;
            while (idx > 0) {
                let parentIdx = Math.floor((idx - 1) / 2);
                if (this.heap[idx].weight >= this.heap[parentIdx].weight) break;
                [this.heap[idx], this.heap[parentIdx]] = [this.heap[parentIdx], this.heap[idx]];
                idx = parentIdx;
            }
        }
        bubbleDown() {
            let idx = 0;
            while (true) {
                let left = 2 * idx + 1, right = 2 * idx + 2, smallest = idx;
                if (left < this.heap.length && this.heap[left].weight < this.heap[smallest].weight) smallest = left;
                if (right < this.heap.length && this.heap[right].weight < this.heap[smallest].weight) smallest = right;
                if (smallest === idx) break;
                [this.heap[idx], this.heap[smallest]] = [this.heap[smallest], this.heap[idx]];
                idx = smallest;
            }
        }
    }

    let canvas: HTMLCanvasElement;
    let ctx: CanvasRenderingContext2D;
    let width: number, height: number, cols: number, rows: number;
    
    interface Edge {
        n1: string; n2: string;
        x1: number; y1: number;
        x2: number; y2: number;
        weight: number; state: number;
        isWrap: boolean;
    }

    let edges: Edge[] = [];
    let redNodes = new Set<string>();
    let blueNodes = new Set<string>();
    let redHeap = new MinHeap();
    let blueHeap = new MinHeap();
    let nodeToEdges = new Map<string, Edge[]>();
    let isFull = false;

    function init() {
        canvas = document.getElementById('percolation-canvas') as HTMLCanvasElement;
        if (!canvas) return;
        ctx = canvas.getContext('2d')!;
        
        setup();
        animate();
    }

    function setup() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
        
        cols = Math.ceil(width / CONFIG.latticeScale) + 1;
        rows = Math.ceil(height / CONFIG.latticeScale) + 1;
        
        edges = [];
        redNodes.clear();
        blueNodes.clear();
        redHeap = new MinHeap();
        blueHeap = new MinHeap();
        nodeToEdges.clear();
        isFull = false;

        for (let i = 0; i < cols; i++) {
            for (let j = 0; j < rows; j++) {
                const x = i * CONFIG.latticeScale;
                const y = j * CONFIG.latticeScale;
                
                const nextI = (i + 1) % cols;
                const nextJ = (j + 1) % rows;

                const eH: Edge = { 
                    n1: `${i},${j}`, n2: `${nextI},${j}`,
                    x1: x, y1: y, x2: nextI < i ? width + CONFIG.latticeScale : nextI * CONFIG.latticeScale, y2: y,
                    weight: Math.random(), state: 0, isWrap: nextI < i
                };
                const eV: Edge = { 
                    n1: `${i},${j}`, n2: `${i},${nextJ}`,
                    x1: x, y1: y, x2: x, y2: nextJ < j ? height + CONFIG.latticeScale : nextJ * CONFIG.latticeScale,
                    weight: Math.random(), state: 0, isWrap: nextJ < j
                };
                edges.push(eH, eV);
                [eH.n1, eH.n2].forEach(n => { if(!nodeToEdges.has(n)) nodeToEdges.set(n, []); nodeToEdges.get(n)!.push(eH); });
                [eV.n1, eV.n2].forEach(n => { if(!nodeToEdges.has(n)) nodeToEdges.set(n, []); nodeToEdges.get(n)!.push(eV); });
            }
        }

        function addSeed(type: number) {
            const node = `${Math.floor(Math.random() * cols)},${Math.floor(Math.random() * rows)}`;
            if (type === 1) redNodes.add(node); else blueNodes.add(node);
            nodeToEdges.get(node)?.forEach(e => {
                if (e.state === 0) (type === 1 ? redHeap : blueHeap).push({ edge: e, weight: e.weight });
            });
        }

        for (let k = 0; k < 3; k++) { addSeed(1); addSeed(2); }
    }

    function draw() {
        ctx.clearRect(0, 0, width, height);
        
        // Background grid
        ctx.strokeStyle = CONFIG.bgLineColor;
        ctx.lineWidth = 1;
        ctx.beginPath();
        for (let e of edges) {
            if (e.state === 0) {
                ctx.moveTo(e.x1, e.y1);
                ctx.lineTo(e.x2, e.y2);
            }
        }
        ctx.stroke();

        // Fluids
        ctx.lineWidth = CONFIG.lineWidth;
        ctx.lineCap = 'round';
        
        // Red
        ctx.strokeStyle = CONFIG.colorRed;
        ctx.beginPath();
        for (let e of edges) {
            if (e.state === 1) {
                ctx.moveTo(e.x1, e.y1);
                ctx.lineTo(e.x2, e.y2);
            }
        }
        ctx.stroke();

        // Blue
        ctx.strokeStyle = CONFIG.colorBlue;
        ctx.beginPath();
        for (let e of edges) {
            if (e.state === 2) {
                ctx.moveTo(e.x1, e.y1);
                ctx.lineTo(e.x2, e.y2);
            }
        }
        ctx.stroke();
    }

    function animate() {
        if (!isFull) {
            for (let s = 0; s < CONFIG.growthSpeed; s++) {
                for (let r = 0; r < CONFIG.expansionRate; r++) {
                    const rMove = redHeap.pop();
                    if (rMove && rMove.edge.state === 0 && rMove.weight < CONFIG.threshold) {
                        rMove.edge.state = 1;
                        [rMove.edge.n1, rMove.edge.n2].forEach(n => {
                            if (!redNodes.has(n)) {
                                redNodes.add(n);
                                nodeToEdges.get(n)?.forEach(e => {
                                    if (e.state === 0) redHeap.push({ edge: e, weight: e.weight });
                                });
                            }
                        });
                    }
                    const bMove = blueHeap.pop();
                    if (bMove && bMove.edge.state === 0 && bMove.weight < CONFIG.threshold) {
                        bMove.edge.state = 2;
                        [bMove.edge.n1, bMove.edge.n2].forEach(n => {
                            if (!blueNodes.has(n)) {
                                blueNodes.add(n);
                                nodeToEdges.get(n)?.forEach(e => {
                                    if (e.state === 0) blueHeap.push({ edge: e, weight: e.weight });
                                });
                            }
                        });
                    }
                }
                
                // If the next best move in both heaps is ABOVE the threshold, we are stuck
                const rTop = redHeap.peek();
                const bTop = blueHeap.peek();
                const rLocked = !rTop || rTop.weight >= CONFIG.threshold;
                const bLocked = !bTop || bTop.weight >= CONFIG.threshold;

                if (rLocked && bLocked) { isFull = true; break; }
            }
        }

        draw();
        requestAnimationFrame(animate);
    }

    window.addEventListener('resize', setup);
    init();
</script>
